<header class="topbar">
  <div class="topbar-left">
    <button class="mobile-hamburger" id="mobileHamburger">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="topbar-search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" placeholder="Search workspaces, research, builds..." id="globalSearch" />
    </div>
  </div>
  <div class="topbar-right">
    <button class="topbar-icon-btn" title="Notifications">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    </button>
    <div class="user-menu-wrap">
      <div class="user-avatar-btn" id="userMenuBtn">
        <% if (user && user.avatar) { %>
          <img src="<%= user.avatar %>" alt="" class="user-avatar" />
        <% } else { %>
          <div class="user-avatar-fallback"><%= user ? user.username.slice(0,2).toUpperCase() : 'AC' %></div>
        <% } %>
      </div>
      <div class="user-dropdown" id="userDropdown">
        <div class="user-dropdown-header">
          <div class="user-dropdown-name"><%= user ? user.username : 'Guest' %></div>
          <div class="user-dropdown-email"><%= user ? user.email : '' %></div>
        </div>
        <a href="/profile" class="user-dropdown-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Profile & Settings
        </a>
        <a href="/analytics" class="user-dropdown-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          Analytics
        </a>
        <form action="/auth/logout" method="POST" style="margin:0">
          <button type="submit" class="user-dropdown-link danger">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign Out
          </button>
        </form>
      </div>
    </div>
  </div>
</header>
