<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/global.css" />
</head>
<body>
  <div style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:24px">
    <div style="font-family:var(--font-ui);font-size:80px;font-weight:800;color:var(--purple);line-height:1;margin-bottom:16px">404</div>
    <h1 style="font-size:24px;font-weight:700;margin-bottom:10px">Page not found</h1>
    <p style="font-family:var(--font-body);color:var(--gray);margin-bottom:28px;max-width:380px">The page you're looking for doesn't exist or may have been moved.</p>
    <a href="/" class="btn btn-purple">Back to Home</a>
  </div>
</body>
</html>
