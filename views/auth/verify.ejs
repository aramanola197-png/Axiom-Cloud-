<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/images/favicon.png" type="image/png" onerror="this.remove()" />
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>
<div class="auth-page">
  <div class="auth-glow"></div>
  <div class="auth-card">
    <a href="/" class="auth-logo">
      <img src="/images/logo.png" alt="" class="auth-logo-img" onerror="this.style.display='none'" />
      <span class="auth-logo-text">Axiom<span style="color:var(--purple)">.</span>Cloud</span>
    </a>
    <div class="auth-box">
      <h1 class="auth-title">Verify your email</h1>
      <p class="auth-sub">We sent a 6-digit code to <span class="email-highlight"><%= email %></span></p>

      <% if (error && error !== 'incorrect_code') { %>
        <div class="auth-error">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <form class="auth-form" id="verifyForm" action="/auth/verify" method="POST">
        <input type="hidden" name="code" id="codeHidden" />
        <div class="otp-wrap" id="otpWrap">
          <input type="text" class="otp-box otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
          <input type="text" class="otp-box otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
          <input type="text" class="otp-box otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
          <input type="text" class="otp-box otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
          <input type="text" class="otp-box otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
          <input type="text" class="otp-box otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
        </div>
        <button type="submit" class="btn btn-red auth-submit" style="margin-top:8px">Verify Email</button>
      </form>

      <p class="resend-text">
        Didn't receive the code?
        <span class="resend-link" id="resendLink">Resend code</span>
      </p>
    </div>
  </div>
</div>

<script>
  const wasIncorrect = <%- error === 'incorrect_code' ? 'true' : 'false' %>;
  const inputs = document.querySelectorAll('.otp-input');
  const otpWrap = document.getElementById('otpWrap');
  const codeHidden = document.getElementById('codeHidden');
  const verifyForm = document.getElementById('verifyForm');
  const resendLink = document.getElementById('resendLink');

  inputs.forEach((input, idx) => {
    input.addEventListener('input', (e) => {
      const val = e.target.value.replace(/[^0-9]/g, '');
      e.target.value = val;
      if (val && idx < inputs.length - 1) inputs[idx + 1].focus();
      input.classList.remove('error');
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Backspace' && !e.target.value && idx > 0) {
        inputs[idx - 1].focus();
      }
    });
    input.addEventListener('paste', (e) => {
      e.preventDefault();
      const paste = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '').slice(0, 6);
      paste.split('').forEach((char, i) => {
        if (inputs[i]) inputs[i].value = char;
      });
      if (paste.length === 6) inputs[5].focus();
    });
  });

  verifyForm.addEventListener('submit', (e) => {
    const code = Array.from(inputs).map(i => i.value).join('');
    if (code.length !== 6) {
      e.preventDefault();
      otpWrap.classList.add('shake');
      inputs.forEach(i => i.classList.add('error'));
      setTimeout(() => otpWrap.classList.remove('shake'), 400);
      return;
    }
    codeHidden.value = code;
  });

  if (wasIncorrect) {
    otpWrap.classList.add('shake');
    inputs.forEach(i => { i.classList.add('error'); i.value = ''; });
    setTimeout(() => otpWrap.classList.remove('shake'), 400);
    inputs[0].focus();
  } else {
    inputs[0].focus();
  }

  let resendCooldown = 0;
  function startCooldown() {
    resendCooldown = 30;
    resendLink.classList.add('disabled');
    const tick = () => {
      resendLink.textContent = `Resend in ${resendCooldown}s`;
      resendCooldown--;
      if (resendCooldown >= 0) setTimeout(tick, 1000);
      else {
        resendLink.textContent = 'Resend code';
        resendLink.classList.remove('disabled');
      }
    };
    tick();
  }

  resendLink.addEventListener('click', async () => {
    if (resendLink.classList.contains('disabled')) return;
    resendLink.textContent = 'Sending...';
    try {
      const res = await fetch('/auth/resend-code', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      const data = await res.json();
      if (data.success) {
        startCooldown();
      } else {
        resendLink.textContent = 'Resend code';
        alert(data.message || 'Could not resend code.');
      }
    } catch (err) {
      resendLink.textContent = 'Resend code';
      alert('Network error. Please try again.');
    }
  });

  startCooldown();
</script>
</body>
</html>
