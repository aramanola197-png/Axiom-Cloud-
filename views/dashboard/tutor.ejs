<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/images/favicon.png" type="image/png" onerror="this.remove()" />
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/dashboard.css" />
  <link rel="stylesheet" href="/css/chat.css" />
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.6/dist/purify.min.js"></script>
</head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="chat-layout">
      <div class="chat-history-sidebar">
        <button class="chat-new-btn" onclick="window.location.href='/tutor'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          New Topic
        </button>
        <div class="chat-history-title">History</div>
        <% if (sessions && sessions.length) { %>
          <% sessions.forEach(function(s) { %>
            <a href="/tutor/session/<%= s._id %>" class="chat-history-item <%= currentSession && currentSession._id.toString() === s._id.toString() ? 'active' : '' %>"><%= s.title %></a>
          <% }); %>
        <% } else { %>
          <p style="font-size:12px;color:var(--gray2);padding:8px 10px;font-family:var(--font-body)">No sessions yet.</p>
        <% } %>
      </div>

      <div class="chat-main">
        <% if (!currentSession) { %>
          <div class="chat-empty">
            <div class="chat-empty-icon"><svg viewBox="0 0 24 24"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg></div>
            <h2 class="chat-empty-title">AI Tutor</h2>
            <p class="chat-empty-desc">Learn anything — business concepts, technical architecture, or industry terms — explained clearly, at your level.</p>
            <form class="chat-start-form" id="startForm">
              <div class="chat-start-input-wrap">
                <input type="text" class="chat-start-input" id="startInput" placeholder="What do you want to learn?" required />
                <button type="submit" class="chat-start-submit" id="startSubmit">
                  <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
              </div>
            </form>
            <div class="chat-suggestions">
              <span class="chat-suggestion-chip">Quantum computing basics</span>
              <span class="chat-suggestion-chip">How blockchains work</span>
              <span class="chat-suggestion-chip">SaaS pricing models</span>
              <span class="chat-suggestion-chip">REST vs GraphQL</span>
            </div>
          </div>
        <% } else { %>
          <div class="chat-messages" id="chatMessages">
            <% currentSession.messages.forEach(function(m) { %>
              <div class="msg <%= m.role %>">
                <div class="msg-avatar"><%= m.role === 'user' ? (user.username.slice(0,2).toUpperCase()) : 'AI' %></div>
                <div class="msg-body">
                  <div class="msg-name"><%= m.role === 'user' ? user.username : 'AI Tutor' %></div>
                  <div class="msg-content prose"><span class="raw-content" data-content="<%= encodeURIComponent(m.content) %>"></span></div>
                  <% if (m.quiz && m.quiz.length) { %>
                    <div class="quiz-wrap" data-quiz="<%= encodeURIComponent(JSON.stringify(m.quiz)) %>"></div>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
          <div class="chat-input-area">
            <div style="max-width:760px;margin:0 auto 12px;text-align:center">
              <button class="quiz-btn" id="generateQuizBtn">Generate Quiz</button>
            </div>
            <div class="chat-input-wrap">
              <textarea class="chat-input" id="chatInput" placeholder="Ask a follow-up..." rows="1"></textarea>
              <button class="chat-send-btn" id="chatSend">
                <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </button>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script src="/js/dashboard.js"></script>
<script src="/js/quiz-render.js"></script>
<script>
  const sessionId = <%- currentSession ? `"${currentSession._id}"` : 'null' %>;
  document.querySelectorAll('.raw-content').forEach(el => {
    el.parentElement.innerHTML = DOMPurify.sanitize(marked.parse(decodeURIComponent(el.dataset.content)));
  });
  document.querySelectorAll('.quiz-wrap').forEach(el => {
    const quiz = JSON.parse(decodeURIComponent(el.dataset.quiz));
    renderQuiz(el, quiz);
  });

  const startForm = document.getElementById('startForm');
  if (startForm) {
    document.querySelectorAll('.chat-suggestion-chip').forEach(chip => {
      chip.addEventListener('click', () => { document.getElementById('startInput').value = chip.textContent; });
    });
    startForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const topic = document.getElementById('startInput').value.trim();
      if (!topic) return;
      const submitBtn = document.getElementById('startSubmit');
      submitBtn.disabled = true; submitBtn.innerHTML = '<div class="spinner"></div>';
      try {
        const res = await fetch('/tutor/start', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ topic, workspaceId: window.currentWorkspaceId }),
        });
        const data = await res.json();
        if (data.success) window.location.href = `/tutor/session/${data.sessionId}`;
        else { showToast(data.message || 'Something went wrong.', 'error'); submitBtn.disabled = false; }
      } catch (err) { showToast('Network error.', 'error'); submitBtn.disabled = false; }
    });
  }

  const chatInput = document.getElementById('chatInput');
  const chatSend = document.getElementById('chatSend');
  const chatMessages = document.getElementById('chatMessages');
  if (chatInput) {
    chatInput.addEventListener('input', () => { chatInput.style.height = 'auto'; chatInput.style.height = Math.min(chatInput.scrollHeight, 140) + 'px'; });
    chatInput.addEventListener('keydown', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } });
    chatSend.addEventListener('click', sendMessage);
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
  function addMessage(role, content, name) {
    const div = document.createElement('div');
    div.className = `msg ${role}`;
    const initials = role === 'user' ? '<%= user.username.slice(0,2).toUpperCase() %>' : 'AI';
    div.innerHTML = `<div class="msg-avatar">${initials}</div><div class="msg-body"><div class="msg-name">${name}</div><div class="msg-content prose">${role === 'assistant' ? DOMPurify.sanitize(marked.parse(content)) : escapeHtml(content)}</div></div>`;
    chatMessages.appendChild(div); chatMessages.scrollTop = chatMessages.scrollHeight;
  }
  function addTyping() {
    const div = document.createElement('div'); div.className = 'msg assistant'; div.id = 'typingIndicator';
    div.innerHTML = `<div class="msg-avatar">AI</div><div class="msg-body"><div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>`;
    chatMessages.appendChild(div); chatMessages.scrollTop = chatMessages.scrollHeight;
  }
  async function sendMessage() {
    const message = chatInput.value.trim();
    if (!message || !sessionId) return;
    chatInput.value = ''; chatInput.style.height = 'auto';
    addMessage('user', message, '<%= user.username %>');
    addTyping(); chatSend.disabled = true;
    try {
      const res = await fetch(`/tutor/message/${sessionId}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message }) });
      const data = await res.json();
      document.getElementById('typingIndicator')?.remove();
      if (data.success) addMessage('assistant', data.response, 'AI Tutor');
      else showToast(data.message || 'Something went wrong.', 'error');
    } catch (err) { document.getElementById('typingIndicator')?.remove(); showToast('Network error.', 'error'); }
    chatSend.disabled = false;
  }
  if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;

  const generateQuizBtn = document.getElementById('generateQuizBtn');
  if (generateQuizBtn) {
    generateQuizBtn.addEventListener('click', async () => {
      generateQuizBtn.disabled = true;
      generateQuizBtn.innerHTML = '<div class="spinner"></div> Generating quiz...';
      try {
        const res = await fetch(`/tutor/quiz/${sessionId}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          const div = document.createElement('div');
          div.className = 'msg assistant';
          div.innerHTML = `<div class="msg-avatar">AI</div><div class="msg-body"><div class="msg-name">AI Tutor</div><div class="msg-content prose">Here is a quick quiz to check your understanding:</div><div class="quiz-wrap"></div></div>`;
          chatMessages.appendChild(div);
          renderQuiz(div.querySelector('.quiz-wrap'), data.quiz);
          chatMessages.scrollTop = chatMessages.scrollHeight;
        } else {
          showToast(data.message || 'Could not generate quiz.', 'error');
        }
      } catch (err) {
        showToast('Network error.', 'error');
      }
      generateQuizBtn.disabled = false;
      generateQuizBtn.innerHTML = 'Generate Quiz';
    });
  }
</script>
</body>
</html>
