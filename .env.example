# ============================================================
#  AXIOM CLOUD — ENVIRONMENT VARIABLES
#  This is the ONLY file you should ever need to edit.
#  Copy this file, rename the copy to ".env", then fill in the values below.
#  Never share this file or commit it to GitHub.
#
#  IMPORTANT: The app is designed to START and STAY RUNNING even if some
#  of the values below are missing. Pages that need a missing credential
#  will show a friendly "not configured yet" message instead of crashing.
#  Fill in what you have now, and add the rest later — nothing breaks.
# ============================================================

# ── APP ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Set NODE_ENV=production ONLY when deploying to a live HTTPS domain.
# Keep it as "development" while testing locally on http://localhost — otherwise login cookies will not work over plain HTTP.
APP_URL=http://localhost:3000
# When deployed, change APP_URL to your live domain e.g. https://axiomcloud.com

# ── SESSION SECRET ───────────────────────────────────────────
# Generate a random string. You can use: https://generate-secret.vercel.app/64
SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARACTERS

# ── MONGODB ATLAS ────────────────────────────────────────────
# How to get this:
# 1. Go to https://cloud.mongodb.com and sign up for free
# 2. Create a free cluster (M0 tier — no credit card needed)
# 3. Click "Connect" → "Connect your application"
# 4. Copy the connection string and replace <password> with your DB user password
# If left blank, the app still starts — but login, saved sessions, and all
# AI history (research, builds, pitches, etc) will not persist.
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/axiom-cloud?retryWrites=true&w=majority


# ══════════════════════════════════════════════════════════════
#  AI PROVIDER — read this section carefully
# ══════════════════════════════════════════════════════════════
# Axiom Cloud's entire AI layer is provider-agnostic. Every AI feature
# (Research Studio, AI Tutor, Builder, Board Room, Database Studio,
# Marketplace agents) calls through ONE central service. Switching
# providers below requires changing environment variables ONLY —
# never source code.
#
# Options: 0g | gemini | openai | claude
AI_PROVIDER=0g

# ── 0G COMPUTE (default provider — used when AI_PROVIDER=0g) ────────
# 0G's Router API is OpenAI-compatible, so no special SDK is required.
# Your API key will be supplied separately — paste it below when ready.
ZG_BASE_URL=https://router-api.0g.ai/v1
ZG_API_KEY=
# Default model used across all AI features unless a feature-specific
# model below is set. Leave blank to use the adapter's built-in default.
ZG_DEFAULT_MODEL=

# ── Per-feature model overrides (all optional) ──────────────────────
# Leave any of these blank to fall back to ZG_DEFAULT_MODEL (or the
# provider's built-in default if that's blank too). Use these only if
# you want a specific feature to use a different model than the rest
# of the app — for example, a cheaper model for quizzes and a stronger
# one for the Board Room.
RESEARCH_MODEL=
TUTOR_MODEL=
BOARDROOM_MODEL=
BUILDER_MODEL=
DATABASE_MODEL=

# ── GEMINI (only used when AI_PROVIDER=gemini) ───────────────────────
# Get a key at https://aistudio.google.com → "Get API Key"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── OPENAI (only used when AI_PROVIDER=openai) ───────────────────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── CLAUDE / ANTHROPIC (only used when AI_PROVIDER=claude) ───────────
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6


# ── GOOGLE OAUTH ─────────────────────────────────────────────
# How to get this:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or select existing)
# 3. Go to "APIs & Services" → "OAuth consent screen" → fill in app name
# 4. Go to "APIs & Services" → "Credentials" → "Create Credentials" → "OAuth 2.0 Client ID"
# 5. Application type: Web application
# 6. Add Authorized redirect URI: http://localhost:3000/auth/google/callback
# 7. Copy Client ID and Client Secret below
# If left blank, "Continue with Google" is hidden and only email sign-up works.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── EMAIL / GMAIL SMTP ───────────────────────────────────────
# How to get this:
# 1. Use a Gmail account you own (create a new one for the app if preferred)
# 2. Go to https://myaccount.google.com → Security → 2-Step Verification → enable it
# 3. Go back to Security → search "App passwords"
# 4. Select "Mail" and "Other (Custom name)" → type "Axiom Cloud" → Generate
# 5. Copy the 16-character app password (no spaces) and paste below
# If left blank, sign-up still works but verification emails will fail to send —
# you'll see a clear error rather than a crash.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Axiom Cloud <YOUR_GMAIL_ADDRESS@gmail.com>
